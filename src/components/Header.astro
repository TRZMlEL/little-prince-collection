---
import SearchBar from './SearchBar.astro'
import LanguageToggle from './LanguageToggle.astro'
import type { Locale } from '../i18n/locale'
import { t } from '../i18n/ui'

interface Props {
  title?: string
  showSearch?: boolean
  locale: Locale
}

const { title, showSearch = true, locale } = Astro.props
const base = import.meta.env.BASE_URL || '/'
---

<header class="relative flex w-full flex-wrap items-center gap-4 bg-(--night-sky) px-4 py-4 mb-4 shadow-(--shadow-night-sky) md:pr-32 lg:px-32 xl:px-64 header-anim">
  <a
    href="#main-content"
    class="fixed left-4 top-4 z-50 text-xs bg-(--night-sky) text-white focus:text-(--stars) px-4 py-2 shadow-(--shadow-night-sky) text-center -translate-x-full opacity-0 focus:translate-x-0 focus:opacity-100 transition-all duration-200"
  >
    {t(locale, 'header.skipToMain')}
  </a>

  <h1 class="font-grandhotel text-4xl h-8 flex items-center header-title-anim">
    <a
      href={base}
      class="inline-block text-(--light) hover:text-(--stars) active:text-(--light) transition-transform duration-150 active:scale-95"
    >
      {title || t(locale, 'header.title')}
    </a>
  </h1>


  {showSearch && (
    <div class="order-2 basis-full md:basis-auto md:flex-1 md:min-w-0 lg:ml-auto lg:flex-none lg:w-md header-search-anim">
      <SearchBar
        locale={locale}
        placeholder={t(locale, 'search.placeholder')}
        searchAriaLabel={t(locale, 'search.searchLabel')}
        clearAriaLabel={t(locale, 'search.clearLabel')}
      />
    </div>
  )}

  <LanguageToggle client:visible locale={locale} />
</header>

