---
import type { Locale } from '../i18n/locale'
import { t } from '../i18n/ui'

interface Props {
  count: number
  locale: Locale
}

const { count, locale } = Astro.props
---

<section aria-labelledby="about-collection-title" class="mb-8 w-full about-section-anim">
  <div class="bg-(--night-sky) text-white shadow-(--shadow-night-sky) p-4">
    <div class="flex items-center justify-between gap-4 mb-2 flex-wrap">
      <h2 id="about-collection-title" class="font-grandhotel text-3xl text-(--stars) about-title-anim">{t(locale, 'about.title')}</h2>
      <p class="text-sm bg-(--stars) text-(--night-sky) px-2 py-1 font-semibold about-count-anim">
        {t(locale, 'about.count', { count })}
      </p>
    </div>
    <p class="leading-relaxed text-justify text-(--light) about-description-anim">
      {t(locale, 'about.description')}
    </p>
  </div>
</section>
