---
import Layout from '../layouts/Layout.astro'
import { t } from '../i18n/ui'
import { Image } from 'astro:assets';

import planetSplitLeft from '../../assets/images/planet_split_left.png';
import planetSplitRight from '../../assets/images/planet_split_right.png';

const locale = Astro.locals.locale
const base = import.meta.env.BASE_URL || '/'
---

<Layout title={t(locale, 'notFound.title')} showSearch={false}>
  <div class="mx-auto grid w-full max-w-4xl place-items-center">
    <div class="col-start-1 row-start-1 z-10 flex w-full justify-between sm:px-16 lg:px-0">
      <Image src={planetSplitLeft} alt="" class="pointer-events-none w-30 sm:w-45 md:w-60 lg:w-80" />
      <Image src={planetSplitRight} alt="" class="pointer-events-none w-30 sm:w-45 md:w-60 lg:w-80 scale-88 " />
    </div>

    <div class="col-start-1 row-start-1 z-20 flex min-h-128 sm:h-140 max-h-160 w-full flex-col items-center justify-center text-center">
      <p class="select-none font-grandhotel text-8xl text-(--stars) md:text-9xl text-shadow-sm">404</p>
      <h1 class="mt-6 text-2xl md:text-3xl font-semibold text-(--stars) text-shadow-sm">
        {t(locale, 'notFound.heading')}
      </h1>
      <a
        href={base}
        class="mt-6 inline-block px-6 py-2 text-sm md:text-lg font-bold text-shadow-sm shadow-sm text-(--night-sky) transition-colors duration-200 bg-(--stars) hover:bg-(--light-stars) hover:text-(--dark-night-sky)"
      >
        {t(locale, 'notFound.back')}
      </a>
    </div>
  </div>
</Layout>

<script>
  // @ts-nocheck
  import gsap from 'gsap'

  // Infinite floating animation for planet images
  const animatePlanets = () => {
    const leftPlanet = document.querySelector('img[alt=""]') as HTMLImageElement
    const rightPlanet = document.querySelectorAll('img[alt=""]')[1] as HTMLImageElement

    if (leftPlanet && rightPlanet) {
      // Left planet animation
      gsap.to(leftPlanet, {
        rotate: 5,
        duration: 5,
        ease: 'power1.inOut',
        yoyo: true,
        repeat: -1,
        delay: 3
      })

      gsap.to(leftPlanet, {
        y: -15,
        duration: 2,
        ease: 'power1.inOut',
        yoyo: true,
        repeat: -1,
        delay: 0
      })

      // Right planet animation (slightly different timing for natural feel)
      gsap.to(rightPlanet, {
        y: -13,
        duration: 2.5,
        ease: 'power1.inOut',
        yoyo: true,
        repeat: -1,
        delay: 0.5
      })

      gsap.to(rightPlanet, {
        rotate: -5,
        duration: 4,
        ease: 'power1.inOut',
        yoyo: true,
        repeat: -1,
        delay: 0.5
      })
    }
  }

  // Initialize animation when DOM is ready
  document.addEventListener('DOMContentLoaded', animatePlanets)

  // Re-initialize animation after Astro page transitions (language change)
  document.addEventListener('astro:page-load', () => {
    // Small delay to ensure DOM is updated
    setTimeout(animatePlanets, 10)
  })
</script>